ll id="t-p2-steps" parent="1" style="text;fontSize=10;fontColor=#D32F2F;fontStyle=1;" value="N-1 步" vertex="1"><mxGeometry height="18" width="50" x="725" y="63" as="geometry"/></mxCell><mxCell id="t-p2-g0" parent="1" style="rounded=1;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 0&#xa;a_sum" vertex="1"><mxGeometry height="48" width="130" x="555" y="105" as="geometry"/></mxCell><mxCell id="t-p2-g1" parent="1" style="rounded=1;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 1&#xa;b_sum" vertex="1"><mxGeometry height="48" width="130" x="670" y="213" as="geometry"/></mxCell><mxCell id="t-p2-g2" parent="1" style="rounded=1;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 2&#xa;c_sum" vertex="1"><mxGeometry height="48" width="130" x="555" y="321" as="geometry"/></mxCell><mxCell id="t-p2-g3" parent="1" style="rounded=1;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 3&#xa;d_sum" vertex="1"><mxGeometry height="48" width="130" x="440" y="213" as="geometry"/></mxCell><mxCell id="t-p2-b01" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;fontSize=11;fontStyle=1;dashed=1;dashPattern=8 4;" value="b_sum"><mxGeometry relative="1" as="geometry"><mxPoint x="685" y="129" as="sourcePoint"/><mxPoint x="670" y="237" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-p2-b12" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;fontSize=11;fontStyle=1;dashed=1;dashPattern=8 4;" value="c_sum"><mxGeometry relative="1" as="geometry"><mxPoint x="735" y="261" as="sourcePoint"/><mxPoint x="685" y="345" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-p2-b23" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;fontSize=11;fontStyle=1;dashed=1;dashPattern=8 4;" value="d_sum"><mxGeometry relative="1" as="geometry"><mxPoint x="555" y="345" as="sourcePoint"/><mxPoint x="570" y="237" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-p2-b30" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#D32F2F;fontSize=11;fontStyle=1;dashed=1;dashPattern=8 4;" value="a_sum"><mxGeometry relative="1" as="geometry"><mxPoint x="505" y="213" as="sourcePoint"/><mxPoint x="555" y="129" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-p2-result" parent="1" style="text;fontSize=12;fontColor=#D32F2F;fontStyle=1;whiteSpace=wrap;" value="→ 所有 GPU 集齐完整 [a_sum, b_sum, c_sum, d_sum]" vertex="1"><mxGeometry height="24" width="370" x="440" y="385" as="geometry"/></mxCell><mxCell id="t-pipe-bg" parent="1" style="rounded=1;fillColor=#F3E5F5;strokeColor=#CE93D8;strokeWidth=1.5;dashed=1;" value="" vertex="1"><mxGeometry height="130" width="800" x="15" y="435" as="geometry"/></mxCell><mxCell id="t-pipe-label" parent="1" style="text;fontSize=14;fontStyle=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;rounded=1;" value="流水线化 (Pipelining) — 让 Ring 真正跑满带宽" vertex="1"><mxGeometry height="28" width="360" x="30" y="443" as="geometry"/></mxCell><mxCell id="t-pipe-chunk1" parent="1" style="rounded=1;fillColor=#CE93D8;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=10;fontStyle=1;fontColor=#FFFFFF;" value="Chunk 1&#xa;传输中" vertex="1"><mxGeometry height="38" width="75" x="100" y="490" as="geometry"/></mxCell><mxCell id="t-pipe-arr1" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#7B1FA2;" value=""><mxGeometry relative="1" as="geometry"><mxPoint x="175" y="509" as="sourcePoint"/><mxPoint x="210" y="509" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-pipe-chunk2" parent="1" style="rounded=1;fillColor=#BA68C8;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=10;fontStyle=1;fontColor=#FFFFFF;" value="Chunk 2&#xa;归约中" vertex="1"><mxGeometry height="38" width="75" x="215" y="490" as="geometry"/></mxCell><mxCell id="t-pipe-arr2" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#7B1FA2;" value=""><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="509" as="sourcePoint"/><mxPoint x="325" y="509" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-pipe-chunk3" parent="1" style="rounded=1;fillColor=#AB47BC;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=10;fontStyle=1;fontColor=#FFFFFF;" value="Chunk 3&#xa;准备发送" vertex="1"><mxGeometry height="38" width="75" x="330" y="490" as="geometry"/></mxCell><mxCell id="t-pipe-arr3" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#7B1FA2;" value=""><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="509" as="sourcePoint"/><mxPoint x="440" y="509" as="targetPoint"/></mxGeometry></mxCell><mxCell id="t-pipe-chunk4" parent="1" style="rounded=1;fillColor=#9C27B0;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=10;fontStyle=1;fontColor=#FFFFFF;" value="Chunk 4&#xa;待处理" vertex="1"><mxGeometry height="38" width="75" x="445" y="490" as="geometry"/></mxCell><mxCell id="t-pipe-desc" parent="1" style="text;fontSize=11;fontColor=#7B1FA2;fontStyle=1;" value="数据切分为子块 → 多 chunk 在环上同时流动 → 流水线掩盖延迟" vertex="1"><mxGeometry height="20" width="380" x="30" y="540" as="geometry"/></mxCell><mxCell id="t-pipe-formula" parent="1" style="rounded=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=12;fontStyle=1;" value="通信量 = 2(N-1)/N × 总数据量 ≈ 2× 总数据量（理论最优）&#xa;带宽利用率 ≈ 100%，接近硬件线速" vertex="1"><mxGeometry height="40" width="420" x="175" y="580" as="geometry"/></mxCell></root>
