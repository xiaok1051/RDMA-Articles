      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t-title" parent="1" style="text;fontSize=20;fontStyle=1;fontColor=#333333;" value="Ring AllReduce 算法流程" vertex="1"><mxGeometry height="35" width="350" x="240" y="5" as="geometry"/></mxCell><mxCell id="t-p1-bg" parent="1" style="rounded=1;fillColor=#E3F2FD;strokeColor=#90CAF9;strokeWidth=1;dashed=1;" value="" vertex="1"><mxGeometry height="370" width="390" x="15" y="48" as="geometry"/></mxCell><mxCell id="t-p1-label" parent="1" style="text;fontSize=14;fontStyle=1;fillColor=#BBDEFB;strokeColor=#1565C0;rounded=1;" value="Phase 1: Scatter-Reduce（分散-规约）" vertex="1"><mxGeometry height="28" width="320" x="50" y="58" as="geometry"/></mxCell><mxCell id="t-p1-steps" parent="1" style="text;fontSize=10;fontColor=#1565C0;fontStyle=1;" value="N-1 步" vertex="1"><mxGeometry height="18" width="50" x="315" y="63" as="geometry"/></mxCell><mxCell id="t-p1-g0" parent="1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 0&#xa;[a0,b0,c0,d0]" vertex="1"><mxGeometry height="48" width="130" x="145" y="105" as="geometry"/></mxCell><mxCell id="t-p1-g1" parent="1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 1&#xa;[a1,b1,c1,d1]" vertex="1"><mxGeometry height="48" width="130" x="260" y="213" as="geometry"/></mxCell><mxCell id="t-p1-g2" parent="1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 2&#xa;[a2,b2,c2,d2]" vertex="1"><mxGeometry height="48" width="130" x="145" y="321" as="geometry"/></mxCell><mxCell id="t-p1-g3" parent="1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontSize=12;fontStyle=1;" value="GPU 3&#xa;[a3,b3,c3,d3]" vertex="1"><mxGeometry height="48" width="130" x="30" y="213" as="geometry"/></mxCell><mxCell id="t-p1-a01" edge="1" parent="1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976D2;fontSize=11;