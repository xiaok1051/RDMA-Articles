      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" parent="1" style="text;fontSize=18;fontStyle=1;fontColor=#333333;" value="NCCL 通信算法对比" vertex="1"><mxGeometry height="35" width="300" x="280" y="10" as="geometry"/></mxCell><mxCell id="ring-box" parent="1" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" value="" vertex="1"><mxGeometry height="320" width="230" x="30" y="60" as="geometry"/></mxCell><mxCell id="ring-title" parent="1" style="text;fontSize=15;fontStyle=1;fillColor=#A5D6A7;strokeColor=#2E7D32;rounded=1;" value="Ring 算法" vertex="1"><mxGeometry height="35" width="190" x="50" y="70" as="geometry"/></mxCell><mxCell id="ring-mech" parent="1" style="text;fontSize=11;fillColor=none;align=left;spacingLeft=5;whiteSpace=wrap;" value="GPU连成环，数据逐块传递&#xa;流水线化并行" vertex="1"><mxGeometry height="45" width="210" x="40" y="115" as="geometry"/></mxCell><mxCell id="ring-pro" parent="1" style="text;fontSize=11;fillColor=none;align=left;spacingLeft=5;fontColor=#2E7D32;whiteSpace=wrap;" value="带宽利用率最高&#xa;每卡只发收一个块 接近线速" vertex="1"><mxGeometry height="50" width="210" x="40" y="160" as="geometry"/></mxCell><mxCell id="ring-con" parent="1" style="text;fontSize=11;fillColor=none;align=left;spacingLeft=5;fontColor=#D32F2F;whiteSpace=wrap;" value="延迟 O(N)&#xa;N-1步，GPU多时步数多" vertex="1"><mxGeometry height="45" width="210" x="40" y="215" as="geometry"/></mxCell><mxCell id="ring-fit" parent="1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;whiteSpace=wrap;" value="适合: 大消息 (≥几十 MB)&#xa;搭配 Simple/LL128 协议" vertex="1"><mxGeometry height="55" width="200" x="45" y="290" as="geometry"/></mxCell><mxCell id="tree-box" parent="1" style="rounded=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" value="" vertex="1"><mxGeometry height="320" width="230" x="280" y="60" as="geometry"/></mxCell><mxCell id="tree-title" parent="1" style="text;fontSize=15;fontStyle=1;fillColor=#90CAF9;strokeColor=#1565C0;rounded=1;" value=