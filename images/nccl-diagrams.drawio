" x="540" y="180" as="geometry"/></mxCell><mxCell id="coll-con" parent="1" style="text;fontSize=11;fillColor=none;align=left;spacingLeft=5;fontColor=#D32F2F;whiteSpace=wrap;" value="需要NVSwitch硬件&#xa;仅高端DGX服务器支持" vertex="1"><mxGeometry height="45" width="210" x="540" y="230" as="geometry"/></mxCell><mxCell id="coll-fit" parent="1" style="rounded=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;fontStyle=1;whiteSpace=wrap;" value="适合: NVSwitch场景&#xa;与Simple协议搭配" vertex="1"><mxGeometry height="55" width="200" x="545" y="290" as="geometry"/></mxCell></root>
